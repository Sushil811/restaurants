# ─── Server Configuration ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/lumiere

# ─── Authentication (JWT) ─────────────────────────────────────────────────────
JWT_SECRET=your_jwt_super_secret_key_at_least_32_characters_long
JWT_EXPIRE=7d
REFRESH_TOKEN_EXPIRE=30d

# ─── Email Service (Nodemailer SMTP) ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=Lumiere Restaurant <noreply@lumiere.com>
ADMIN_EMAIL=admin@lumiere.com

# ─── Payment Service (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Media Storage (Cloudinary) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=restaurants
CLOUDINARY_API_KEY=791135594458128
